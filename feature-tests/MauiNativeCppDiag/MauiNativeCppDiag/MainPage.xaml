<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiNativeCppDiag.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Image
                Source="dotnet_bot.png"
                HeightRequest="185"
                Aspect="AspectFit"
                SemanticProperties.Description="dot net bot in a submarine number ten" />

            <Label
                Text="Welcome to &#10;.NET Multi-platform App UI"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level2"
                SemanticProperties.Description="Welcome to dot net Multi platform App U I" />

            <Button
                x:Name="SetSampleStringBtn"
                Text="Set Sample String" 
                SemanticProperties.Hint="Set a sample string"
                Clicked="OnSetSampleStringBtnClicked"
                HorizontalOptions="Fill" />

            <Button
                x:Name="TestBtn"
                Text="Test Native Library" 
                SemanticProperties.Hint="Test native library using from MAUI app"
                Clicked="OnTestBtnClicked"
                HorizontalOptions="Fill" />

            <Label
                x:Name="SeedLabel"
                Text="Seed will appear here"
                HorizontalOptions="Center" />
            
            <Label
                x:Name="ResultLabel"
                Text="Result will appear here"
                HorizontalOptions="Center" />

            <Button
                x:Name="TestBtnDirect"
                Text="Test Native Library - Direct Call" 
                Clicked="OnTestBtnDirectClicked"
                HorizontalOptions="Fill" />
            <Button
                x:Name="TestBtnNativeCpp"
                Text="Test Native Library - NativeCpp" 
                Clicked="OnTestBtnNativeCppClicked"
                HorizontalOptions="Fill" />

            <Label
                x:Name="ResultLabelDirect"
                Text="Result will appear here"
                HorizontalOptions="Center" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
